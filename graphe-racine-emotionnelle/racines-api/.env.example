# Copier en .env (jamais committé) puis renseigner.
# ── Neo4j ──
NEO4J_PASSWORD=change-me

# ── LLM (Spring AI) ──
# Fournisseur de CHAT : openai | ollama | anthropic.
#   - openai    → LLM_API_KEY requise (compte facturé)
#   - ollama    → local, aucune clé
#   - anthropic → ANTHROPIC_API_KEY requise (Claude)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_API_KEY=sk-...                  # clé OpenAI : seulement si chat OU embedding = openai
LLM_CHAT_MODEL=claude-opus-4-8      # openai: gpt-4o-mini · ollama: llama3 · anthropic: claude-*
LLM_MAX_TOKENS=1024                 # plafond de tokens en sortie (chat)

# Fournisseur d'EMBEDDING, découplé du chat (Anthropic n'en fournit pas).
# Par défaut = LLM_PROVIDER. Combo recommandé : chat=anthropic + embedding=ollama
# → embeddings locaux GRATUITS, sans clé. Alternatives : openai (1536, payant).
EMBEDDING_PROVIDER=ollama
LLM_EMBED_MODEL=nomic-embed-text    # ollama: nomic-embed-text · openai: text-embedding-3-small
# Dimension de l'index vectoriel = celle du modèle d'embedding.
# nomic-embed-text (ollama) = 768 · text-embedding-3-small (openai) = 1536
RACINES_EMBEDDING_DIMENSIONS=768

# ── Front ──
RACINES_CORS_ORIGINS=http://localhost:5173
