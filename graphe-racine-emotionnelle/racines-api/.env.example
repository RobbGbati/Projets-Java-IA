# Copier en .env (jamais committé) puis renseigner.
# ── Neo4j ──
NEO4J_PASSWORD=change-me

# ── LLM (Spring AI) ──
# Fournisseur : openai | ollama. Avec ollama, LLM_API_KEY est inutile.
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small
# Dimension de l'index vectoriel = celle du modèle d'embedding.
# text-embedding-3-small = 1536 · nomic-embed-text (ollama) = 768
RACINES_EMBEDDING_DIMENSIONS=1536

# ── Front ──
RACINES_CORS_ORIGINS=http://localhost:5173
